# classifier-service/.env.example

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/classifier_db

# Redis connection string for session storage
# Format: redis://host:port/db
REDIS_URL=redis://localhost:6379/0

# Secret key for inter-service authentication
# Generate a random secure string for production
SERVICE_SHARED_SECRET=your-secure-random-secret-here

# Anthropic API key for Claude access
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here   